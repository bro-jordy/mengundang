generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model User {
  id             String       @id @default(cuid())
  email          String       @unique
  password       String
  name           String
  role           UserRole     @default(ADMIN)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  clientUsers    ClientUser[]
  createdClients Client[]     @relation("ClientCreatedBy")

  @@map("users")
}

model Client {
  id               String            @id @default(cuid())
  name             String
  slug             String            @unique
  status           ClientStatus      @default(DRAFT)
  clientType       ClientType        @default(WEDDING)
  customDomain     String?           @unique
  createdById      String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  analytics        Analytics[]
  clientUsers      ClientUser[]
  createdBy        User              @relation("ClientCreatedBy", fields: [createdById], references: [id])
  events           Event[]
  galleries        Gallery[]
  gifts            Gift[]
  guests           Guest[]
  loveStories      LoveStory[]
  musics           Music[]
  sections         Section[]
  theme            Theme?
  weddingProfile   WeddingProfile?
  whatsappTemplate WhatsappTemplate?
  wishes           Wish[]

  @@map("clients")
}

model ClientUser {
  id       String @id @default(cuid())
  userId   String
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, clientId])
  @@map("client_users")
}

model WeddingProfile {
  id             String   @id @default(cuid())
  clientId       String   @unique
  groomName      String   @default("")
  brideName      String   @default("")
  groomNickname  String   @default("")
  brideNickname  String   @default("")
  groomParents   String   @default("")
  brideParents   String   @default("")
  groomPhoto     String?
  bridePhoto     String?
  showGroomPhoto Boolean  @default(true)
  showBridePhoto Boolean  @default(true)
  heroImage      String?
  story           String?
  storyTitle      String?
  showStoryTitle  Boolean  @default(true)
  openingQuote    String?
  openingQuoteBy  String?
  attentionTitle  String?
  attentionContent String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  client         Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("wedding_profiles")
}

model Event {
  id           String    @id @default(cuid())
  clientId     String
  type         EventType
  label        String    @default("")
  date         DateTime?
  timeStart    String    @default("")
  timeEnd      String    @default("")
  venueName    String    @default("")
  venueAddress String    @default("")
  mapsUrl      String    @default("")
  mapsEmbed    String    @default("")
  sortOrder    Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  client       Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("events")
}

model Gallery {
  id        String      @id @default(cuid())
  clientId  String
  url       String
  type      GalleryType @default(GALLERY)
  isCover   Boolean     @default(false)
  sortOrder Int         @default(0)
  createdAt DateTime    @default(now())
  client    Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("galleries")
}

model Theme {
  id             String   @id @default(cuid())
  clientId       String   @unique
  templateSlug   String   @default("classic")
  primaryColor   String   @default("#b8860b")
  secondaryColor String   @default("#f5f0e8")
  bgColor        String   @default("#fffdf7")
  textColor      String   @default("#3d3d3d")
  fontHeading    String   @default("Playfair Display")
  fontBody       String   @default("Lato")
  customCss      String?
  showCountdown      Boolean  @default(false)
  barcodeVisibility  String   @default("AFTER_RSVP")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  showMap            Boolean  @default(true)
  client         Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("themes")
}

model Music {
  id        String   @id @default(cuid())
  clientId  String
  title     String   @default("")
  url       String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("musics")
}

model Section {
  id         String     @id @default(cuid())
  clientId   String
  sectionKey SectionKey
  isActive   Boolean    @default(true)
  sortOrder  Int        @default(0)
  client     Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, sectionKey])
  @@map("sections")
}

model Guest {
  id                 String             @id @default(cuid())
  clientId           String
  name               String
  phone              String?
  email              String?
  invitationCategory InvitationCategory @default(GEREJA_RESEPSI)
  barcodeChurch      String?            @unique
  barcodeReception   String?            @unique
  guestToken         String             @unique @default("")
  invitationUrl      String             @default("")
  maxPax             Int                @default(2)
  isOpened           Boolean            @default(false)
  openedAt           DateTime?
  rsvpStatus         RsvpStatus         @default(PENDING)
  sendStatus         GuestSendStatus    @default(UNSENT)
  isActive           Boolean            @default(true)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  attendances        Attendance[]
  visits             GuestVisit[]
  client             Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  rsvp               Rsvp?
  wishes             Wish[]

  @@map("guests")
}

model GuestVisit {
  id        String   @id @default(cuid())
  guestId   String
  clientId  String
  ipAddress String?
  userAgent String?
  device    String?
  openedAt  DateTime @default(now())
  guest     Guest    @relation(fields: [guestId], references: [id], onDelete: Cascade)

  @@map("guest_visits")
}

model Rsvp {
  id        String     @id @default(cuid())
  guestId   String     @unique
  clientId  String
  name      String
  paxCount  Int        @default(1)
  status    RsvpStatus @default(HADIR)
  message   String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  guest     Guest      @relation(fields: [guestId], references: [id], onDelete: Cascade)

  @@map("rsvps")
}

model Wish {
  id         String   @id @default(cuid())
  clientId   String
  guestId    String?
  name       String
  message    String
  reply      String?
  isApproved Boolean  @default(true)
  createdAt  DateTime @default(now())
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  guest      Guest?   @relation(fields: [guestId], references: [id])

  @@map("wishes")
}

model Gift {
  id            String   @id @default(cuid())
  clientId      String
  bankName      String?
  accountNumber String?
  accountName   String?
  ewalletType   String?
  ewalletNumber String?
  qrisImage     String?
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  client        Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("gifts")
}

model LoveStory {
  id          String    @id @default(cuid())
  clientId    String
  title       String
  date        DateTime?
  description String
  imageUrl    String?
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  client      Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("love_stories")
}

model Analytics {
  id        String   @id @default(cuid())
  clientId  String
  eventType String
  guestId   String?
  ipAddress String?
  device    String?
  userAgent String?
  createdAt DateTime @default(now())
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("analytics")
}

model WhatsappTemplate {
  id             String   @id @default(cuid())
  clientId       String   @unique
  bodyTemplate   String
  bodyTemplateEn String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  client         Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("whatsapp_templates")
}

model Attendance {
  id          String         @id @default(cuid())
  guestId     String
  clientId    String
  barcodeType AttendanceType
  arrivedAt   DateTime       @default(now())
  actualPax   Int            @default(1)
  guest       Guest          @relation(fields: [guestId], references: [id], onDelete: Cascade)

  @@unique([guestId, barcodeType])
  @@map("attendances")
}

enum UserRole {
  SUPERADMIN
  ADMIN
  STAFF
}

enum ClientStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum ClientType {
  WEDDING
  SANGJIT
  LAMARAN
}

enum EventType {
  AKAD
  PEMBERKATAN
  RESEPSI
  AFTER_PARTY
  SANGJIT
  LAMARAN
}

enum GalleryType {
  HERO
  COVER
  BACKGROUND
  PREWEDDING
  GALLERY
}

enum GuestSendStatus {
  UNSENT
  SENT
}

enum RsvpStatus {
  PENDING
  HADIR
  TIDAK_HADIR
}

enum InvitationCategory {
  GEREJA_SAJA
  GEREJA_RESEPSI
  AKAD
  AKAD_RESEPSI
  PEMBERKATAN
  PEMBERKATAN_RESEPSI
  SANGJIT
  LAMARAN
}

enum AttendanceType {
  CHURCH
  RECEPTION
}

enum SectionKey {
  HERO
  COUPLE
  EVENT
  GALLERY
  LOVE_STORY
  RSVP
  WISHES
  GIFT
  MAPS
  CLOSING
}
